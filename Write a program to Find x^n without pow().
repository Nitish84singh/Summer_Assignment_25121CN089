def my_pow(x: float, n: int) -> float:
    if n < 0:
        x = 1 / x
        n = -n
    result = 1.0
    current_product = x
    while n > 0:
        if n & 1:
            result *= current_product
        current_product *= current_product
        n >>= 1
    return result
print(my_pow(2, 2))  #output=4.0

#include <stdio.h>
#include <math.h>
int main() {
    int lower, upper, i, j,Prime;
    printf("Enter lower bound: ");
    scanf("%d", &lower);
    printf("Enter upper bound: ");
    scanf("%d", &upper);
    printf("Prime numbers between %d and %d are:\n", lower, upper);
    for (i = lower; i <= upper; i++) {
        if (i < 2) {
            continue;
        }
        Prime = 1;
        for (j = 2; j <= sqrt(i); j++) {
            if (i % j == 0) {
                Prime = 0; 
                break;      
            }
        }
        if (Prime == 1) {
            printf("%d ", i);
        }
    }
    printf("\n");
    return 0;
}

#include <stdio.h>
int gcd(int a, int b) {
    if (b == 0) {
        return a;
    }
    return gcd(b, a % b);
}
int Lcm(int a, int b) {
    if (a == 0 || b == 0) {
        return 0;
    }
    return (a * b) / gcd(a, b);
}
int main() {
    int x,y,lcm;
    printf("Enter two positive integers: ");
    if (scanf("%d %d", &x, &y) != 2) {
        printf("Invalid input.\n");
        return 1;
    }
    lcm = Lcm(x, y);
    printf("The LCM of %d and %d is %d.\n", x, y,lcm);
    return 0;
}

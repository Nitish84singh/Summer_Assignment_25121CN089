#include <stdio.h>
int reverseNumber(int num, int rev) {
    if (num == 0) {
        return rev;
    }
    rev = (rev * 10) + (num % 10);
    return reverseNumber(num / 10, rev);
}
int main() {
    int number;
    printf("Enter an integer: ");
    if (scanf("%d", &number) != 1) {
        printf("Invalid input.\n");
        return 1;
    }
    int reversed = reverseNumber(number, 0);
    printf("Reversed number: %d\n", reversed);
    return 0;
}

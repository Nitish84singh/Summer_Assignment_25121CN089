#include <stdio.h>
int Armstrong(int n) {
    int temp = n, rem, sum = 0;
    while(temp != 0) {
        rem = temp % 10;
        sum = sum + rem * rem * rem;
        temp = temp / 10;
    }
    if(n == sum)
        return 1;
    else
        return 0;
}
int main() {
    int num;
    printf("Enter a number: ");
    scanf("%d", &num);
    if(Armstrong(num))
        printf("Armstrong Number");
    else
        printf("Not an Armstrong Number");\
    return 0;
}
